# ==============================================================================
# LOCAL DEVELOPMENT CONFIGURATION
# ==============================================================================
# This file is for local development only.
#
# For production (Vercel), set these in Vercel dashboard:
# - GROQ_API_KEY (from https://console.groq.com/keys)
# - INNGEST_EVENT_KEY (from https://www.inngest.com/ dashboard)
# - INNGEST_SIGNING_KEY (from https://www.inngest.com/ dashboard)
# - DATABASE_URL (auto-set by Neon integration - don't configure manually)
# ==============================================================================

# Groq API Key (REQUIRED)
# Get free API key: https://console.groq.com/keys
GROQ_API_KEY=your_api_key_here

# Database URL (REQUIRED for Prisma CLI commands: migrate, studio)
# Connects to Docker PostgreSQL from your host machine
# The app running in Docker uses a different DATABASE_URL from docker-compose.yml
# ⚠️  If you change PostgreSQL settings below, update this URL to match!
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llms_txt_dev

# ==============================================================================
# OPTIONAL - Rate Limiting (Production Only)
# ==============================================================================
# Rate limiting requires Upstash Redis (free tier available)
# Get from: https://console.upstash.com/
#
# If not set, rate limiting is disabled (development mode)
# Production (Vercel): Set these in Vercel dashboard
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# ==============================================================================
# OPTIONAL - Structured Logging with next-axiom (Production Only)
# ==============================================================================
# Axiom provides long-term log retention, advanced search, and Web Vitals tracking
# Free tier: 500GB ingestion/month, 30-day retention
# Get from: https://axiom.co/
#
# Setup instructions:
# 1. Create account at https://axiom.co/
# 2. Create dataset (e.g., "llms-txt-logs") - select "events" type
# 3. Create API token with ingest permissions
# 4. Add these to Vercel environment variables
#
# If not set, logs go to console only (visible in Vercel dashboard)
# Production (Vercel): Set these in Vercel dashboard
# NEXT_PUBLIC_AXIOM_TOKEN=xaat-your-api-token
# NEXT_PUBLIC_AXIOM_DATASET=llms-txt-logs

# ==============================================================================
# OPTIONAL - Advanced Configuration (uncomment to customize)
# ==============================================================================
# All settings below have working defaults in docker-compose.yml
# Only uncomment if you need to customize local development setup

# PostgreSQL credentials (defaults: postgres/postgres/llms_txt_dev)
# ⚠️  If you change these, also update DATABASE_URL above to match!
#     Format: postgresql://USER:PASSWORD@localhost:PORT/DATABASE
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=llms_txt_dev
# POSTGRES_PORT=5432
